<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- ── MAIN SCROLLABLE CONTENT ───────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:clipToPadding="false"
        android:scrollbars="none">


        <LinearLayout
            android:id="@+id/contentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── TOP BAR (extends behind status bar) ────────────── -->
            <RelativeLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#121212"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:minHeight="8dp">
            </RelativeLayout>

            <!-- ── DATE ROW ─────────────────────────────────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="Previous day" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Today"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivEdit"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_edit"
                    android:contentDescription="Edit" />
            </RelativeLayout>

            <!-- ── LARGE CALORIE RING ────────────────────────────────── -->
            <FrameLayout
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp">

                <!-- Arc ring drawn by custom view -->
                <com.example.trackfit.CircularProgressView
                    android:id="@+id/cpvCalories"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cpv_progress="1850"
                    app:cpv_maxProgress="2200"
                    app:cpv_trackColor="#2A2A2A"
                    app:cpv_progressColor="#00E5FF"
                    app:cpv_strokeWidth="16dp"
                    app:cpv_sweepDegrees="280"
                    app:cpv_startAngle="130" />

                <!-- Center overlay -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_flame"
                        android:contentDescription="Calories" />

                    <TextView
                        android:id="@+id/tvCaloriesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,850"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kcal"
                        android:textColor="#888888"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ── SUMMARY STATS ROW ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <!-- Steps mini ring -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <com.example.trackfit.CircularProgressView
                            android:id="@+id/cpvStepsSummary"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cpv_progress="8432"
                            app:cpv_maxProgress="10000"
                            app:cpv_trackColor="#2A2A2A"
                            app:cpv_progressColor="#00E5FF"
                            app:cpv_strokeWidth="7dp"
                            app:cpv_sweepDegrees="280"
                            app:cpv_startAngle="130" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_steps"
                            android:contentDescription="Steps" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStepsSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.4k"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEPS"
                        android:textColor="#666666"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Water mini ring -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <com.example.trackfit.CircularProgressView
                            android:id="@+id/cpvWaterSummary"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cpv_progress="1250"
                            app:cpv_maxProgress="2000"
                            app:cpv_trackColor="#2A2A2A"
                            app:cpv_progressColor="#00E5FF"
                            app:cpv_strokeWidth="7dp"
                            app:cpv_sweepDegrees="280"
                            app:cpv_startAngle="130" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_water_drop"
                            android:contentDescription="Water" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvWaterSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2L"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WATER"
                        android:textColor="#666666"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Weight mini ring -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <com.example.trackfit.CircularProgressView
                            android:id="@+id/cpvWeightSummary"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cpv_progress="75"
                            app:cpv_maxProgress="100"
                            app:cpv_trackColor="#2A2A2A"
                            app:cpv_progressColor="#00E5FF"
                            app:cpv_strokeWidth="7dp"
                            app:cpv_sweepDegrees="280"
                            app:cpv_startAngle="130" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_weight"
                            android:contentDescription="Weight" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvWeightSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="75.2"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WEIGHT"
                        android:textColor="#666666"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── ACTIVITY LIST HEADER ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:text="Activity List"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- ── STEPS CARD ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_steps"
                        app:tint="#00E5FF"
                        android:contentDescription="Steps" />
                </FrameLayout>

                <!-- Name + progress in a column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Steps"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvStepsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="8,432"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbSteps"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="10000"
                        android:progress="8432"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── SLEEP CARD ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_sleep"
                        app:tint="#00E5FF"
                        android:contentDescription="Sleep" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Sleep"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvSleepValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="7h 30m"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbSleep"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="480"
                        android:progress="450"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── WATER CARD ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_water_drop"
                        app:tint="#00E5FF"
                        android:contentDescription="Water" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Water"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvWaterValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="1,250 ml"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbWater"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="2000"
                        android:progress="1250"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── FOOD CARD ──────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_food"
                        app:tint="#00E5FF"
                        android:contentDescription="Food" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Food"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvFoodValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="1,850 kcal"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbFood"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="2200"
                        android:progress="1850"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── WEIGHT CARD ────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_weight"
                        app:tint="#00E5FF"
                        android:contentDescription="Weight" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Weight"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvWeightValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="75.2 kg"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbWeight"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="100"
                        android:progress="75"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── CALORIES BURNED CARD ───────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardCaloriesBurned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_icon_circle">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_calories_burned"
                        app:tint="#00E5FF"
                        android:contentDescription="Calories Burned" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Calories Burned"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvCaloriesBurnedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="420 kcal"
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbCaloriesBurned"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:max="600"
                        android:progress="420"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#333333"
                        android:indeterminate="false" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── FLOATING ACTION BUTTON ─────────────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="130dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add Activity"
        app:backgroundTint="#00E5FF"
        app:tint="#000000"
        app:fabSize="normal"
        app:elevation="10dp" />

    <!-- ── BOTTOM NAVIGATION ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <!-- Home (active) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#00E5FF"
                android:textSize="11sp"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Goals -->
        <LinearLayout
            android:id="@+id/navGoals"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_flag"
                android:contentDescription="Goals" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goals"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Profile" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="3dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

