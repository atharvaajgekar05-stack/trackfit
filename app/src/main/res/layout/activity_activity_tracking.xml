<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Top Bar with Back Button and Title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Activity"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Select Activity Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT ACTIVITY"
        android:textColor="#9AAEB3"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Activity Chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupActivity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="false"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        android:layout_marginBottom="24dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWalking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_walking"
            android:text="Walking" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRunning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_running"
            android:text="Running" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCycling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_cycling"
            android:text="Cycling" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSwimming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_swimming"
            android:text="Swimming" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipHiking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_hiking"
            android:text="Hiking" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFootball"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background"
            android:textColor="@color/chip_text_color"
            app:chipIcon="@drawable/ic_football"
            android:text="Football" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Weight -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weight"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_dark"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toStartOf="@+id/tvKg"
                android:background="@null"
                android:hint="Enter weight"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvKg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Kg"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Duration -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="32dp">

            <!-- Hours Input -->
            <RelativeLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp">

                <EditText
                    android:id="@+id/etHours"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/tvH"
                    android:background="@null"
                    android:hint="0"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvH"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Hr"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Minutes Input -->
            <RelativeLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="12dp">

                <EditText
                    android:id="@+id/etMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/tvM"
                    android:background="@null"
                    android:hint="0"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvM"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Min"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Calculate Button -->
        <Button
            android:id="@+id/btnCalculateCalories"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Calculate Calories"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#00E5FF" />

    </LinearLayout>

</LinearLayout>
