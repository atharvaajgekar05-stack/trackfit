<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14"
    android:orientation="vertical"
    android:paddingHorizontal="0dp">

    <!-- Top Bar with Back Button and Title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0B0F14"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="BMI Calculator"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Main ScrollView for content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp">

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Check if your weight is healthy for your height."
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Gender Selection -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/genderGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center">

                <RadioButton
                    android:id="@+id/rbMale"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:button="@null"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/selector_gender_background" />

                <RadioButton
                    android:id="@+id/rbFemale"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:button="@null"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/selector_gender_background" />

            </RadioGroup>

            <!-- Height Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Height"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/btnHeightUnit"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="Enter height"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnHeightUnit"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_card_dark"
                    android:backgroundTint="@null"
                    android:foregroundTint="@null"
                    android:text="cm"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="0dp" />

            </RelativeLayout>

            <!-- Weight Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Weight"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="28dp">

                <EditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/btnWeightUnit"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="Enter weight"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnWeightUnit"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_card_dark"
                    android:backgroundTint="@null"
                    android:foregroundTint="@null"
                    android:text="kg"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="0dp" />

            </RelativeLayout>

            <!-- Calculate Button -->
            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Calculate BMI"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_cyan"
                android:backgroundTint="@null"
                android:foregroundTint="@null"
                android:elevation="0dp"
                android:layout_marginBottom="20dp" />

            <!-- Result Container (initially hidden) -->
            <LinearLayout
                android:id="@+id/resultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- BMI Value Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your BMI is"
                    android:textColor="#C0C0C0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvBmiValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="#39cccc"
                    android:textSize="68sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="28dp" />

                <!-- BMI Range Bar -->
                <LinearLayout
                    android:id="@+id/bmiRangeBar"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="0.27"
                        android:background="#1E88E5"
                        android:layout_marginEnd="1dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="0.27"
                        android:background="#39cccc"
                        android:layout_marginHorizontal="1dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="0.27"
                        android:background="#FFA500"
                        android:layout_marginHorizontal="1dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="0.19"
                        android:background="#EF5350"
                        android:layout_marginStart="1dp" />

                </LinearLayout>

                <!-- BMI Range Labels with Categories -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.25"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&lt; 18.5"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Underweight"
                            android:textColor="#1E88E5"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.30"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="18.5-24.9"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal"
                            android:textColor="#39cccc"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.25"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25-29.9"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overweight"
                            android:textColor="#FFA500"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.20"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8805; 30"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Obese"
                            android:textColor="#EF5350"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Category and Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="30dp">

                    <TextView
                        android:id="@+id/tvBmiCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal weight"
                        android:textColor="#39cccc"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvBmiFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="You have a healthy weight. Great job!"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>






