<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.trackfit">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrackFit">

        <!-- Splash Screen -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Sign Up -->
        <activity
            android:name=".SignupActivity"
            android:exported="false" />

        <!-- Health Metrics -->
        <activity
            android:name=".HealthMetricsActivity"
            android:exported="false" />

        <!-- BMI Calculator -->
        <activity
            android:name=".BmiCalculatorActivity"
            android:exported="false" />

        <!-- Unit Converter -->
        <activity
            android:name=".UnitConverterActivity"
            android:exported="false" />

        <!-- Weight Logger -->
        <activity
            android:name=".WeightLoggerActivity"
            android:exported="false" />

        <!-- Dashboard -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <!-- Profile -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Sleep Tracker -->
        <activity
            android:name=".SleepTrackerActivity"
            android:exported="false" />

        <!-- Main (unused placeholder) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

    </application>

</manifest>






